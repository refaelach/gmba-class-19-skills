---
import Layout from '../../layouts/Layout.astro';
import ToolIcon from '../../components/ToolIcon.astro';
import skillsData from '../../data/skills.json';
import categoriesData from '../../data/categories.json';

type Skill = {
  slug: string;
  category: string;
  name: string;
  title: string;
  description: string;
  summaryLine: string;
  triggers: {
    mandatory: string[];
    strong: string[];
    doNot?: string;
    doWhen?: string;
  };
  bodyHtml: string;
  bodyMarkdown: string;
  sections: Record<string, string | null>;
  tools: string[];
  testedShort: string;
  footer: {
    author?: string;
    authorHandle?: string;
    created?: string;
    testedOn?: string;
    realTasksTested?: string;
  };
  githubPath: string;
  hasReferences: boolean;
};

type Category = {
  slug: string;
  title: string;
  description: string;
  skillCount: number;
};

const skills = skillsData as unknown as Skill[];
const categories = categoriesData as unknown as Category[];

export function getStaticPaths() {
  return (skillsData as unknown as Skill[]).map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const skill = skills.find((s) => s.slug === slug);

if (!skill) {
  throw new Error(`Skill not found: ${slug}`);
}

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const repoUrl = 'https://github.com/refaelach/gmba-class-19-skills';
const category = categories.find((c) => c.slug === skill.category);
const categoryName = category?.title || skill.category;

const githubFileUrl = `${repoUrl}/blob/main/${skill.githubPath}`;
const githubFolderUrl = `${repoUrl}/tree/main/${skill.githubPath.replace(/\/SKILL\.md$/, '')}`;
const githubEditUrl = `${repoUrl}/edit/main/${skill.githubPath}`;
const githubIssueUrl = `${repoUrl}/issues/new?title=${encodeURIComponent('[' + skill.slug + '] ')}`;

// Section render order — only render the ones present.
// Sections shown by default — what a student needs to decide whether to use the skill.
const visibleSections: { key: string; label: string }[] = [
  { key: 'whenToUse', label: 'When to use this skill' },
  { key: 'whenNotToUse', label: 'When NOT to use this skill' },
  { key: 'example', label: 'Example' },
  { key: 'inputs', label: 'Inputs' },
  { key: 'outputs', label: 'Outputs' },
];

// Sections collapsed by default — implementation details for the AI agent and
// for contributors. Useful but not what a student needs at first glance.
const collapsedSections: { key: string; label: string }[] = [
  { key: 'compatibility', label: 'Compatibility' },
  { key: 'howItWorks', label: 'How it works' },
  { key: 'notesForContributors', label: 'Notes for contributors' },
];

const hasCollapsedContent = collapsedSections.some((s) => skill.sections[s.key]);

const tools = skill.tools && skill.tools.length ? skill.tools : ['Claude', 'ChatGPT', 'Gemini'];
const testedShort = skill.testedShort || skill.footer?.testedOn || '';

const pasteTargets = [
  { name: 'ChatGPT', url: 'https://chatgpt.com' },
  { name: 'Claude', url: 'https://claude.ai' },
  { name: 'Gemini', url: 'https://gemini.google.com' },
];
---
<Layout title={`${skill.title} · GMBA Class 19`} description={skill.summaryLine}>
  <div class="skill-page-wrap">
    <div class="container">
      <button class="breadcrumb" data-back-url={baseUrl + '/'}>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        <span>{categoryName}</span>
      </button>

      <header class="skill-header">
        <div class="header-row">
          <span class="chip">{skill.name}</span>
          <span class="mono header-cat">{categoryName}</span>
        </div>
        <h1 class="skill-title h-display">{skill.title}</h1>
        <p class="skill-sub">{skill.summaryLine}</p>
        <div class="metadata-row">
          {skill.footer?.authorHandle && (
            <div>Author <span class="mono meta-val">{skill.footer.authorHandle}</span></div>
          )}
          {testedShort && (
            <div>Tested on <span class="meta-val">{testedShort}</span></div>
          )}
          {skill.footer?.created && (
            <div>Added <span class="mono meta-val">{skill.footer.created}</span></div>
          )}
          <div class="meta-tools">
            <span>Tools</span>
            <div class="tool-dot-row">
              {tools.slice(0, 3).map((t) => (
                <span class="tool-dot" title={t}>
                  <ToolIcon name={t} size={14} />
                </span>
              ))}
            </div>
          </div>
        </div>
      </header>

      <div class="skill-grid">
        <article class="md skill-body">
          {visibleSections.map(({ key, label }) =>
            skill.sections[key] ? (
              <>
                <h2>{label}</h2>
                <Fragment set:html={skill.sections[key] || ''} />
              </>
            ) : null
          )}

          {(skill.triggers.mandatory.length > 0 || skill.triggers.strong.length > 0) && (
            <>
              <h2>Trigger phrases</h2>
              {skill.triggers.mandatory.length > 0 && (
                <div class="trigger-block">
                  <div class="mono trigger-label">MANDATORY</div>
                  <div class="trigger-list">
                    {skill.triggers.mandatory.map((t) => (
                      <code class="code-inline trigger-chip">{t}</code>
                    ))}
                  </div>
                </div>
              )}
              {skill.triggers.strong.length > 0 && (
                <div class="trigger-block">
                  <div class="mono trigger-label">STRONG</div>
                  <div class="trigger-list">
                    {skill.triggers.strong.map((t) => (
                      <code class="code-inline trigger-chip">{t}</code>
                    ))}
                  </div>
                </div>
              )}
              {skill.triggers.doNot && (
                <div class="trigger-block">
                  <div class="mono trigger-label">DO NOT TRIGGER ON</div>
                  <p class="trigger-prose">{skill.triggers.doNot}</p>
                </div>
              )}
            </>
          )}

          {hasCollapsedContent && (
            <details class="impl-details">
              <summary>
                <span class="mono impl-summary-label">Implementation details</span>
                <span class="impl-summary-hint">— for the AI agent &amp; future contributors</span>
              </summary>
              <div class="impl-body">
                {collapsedSections.map(({ key, label }) =>
                  skill.sections[key] ? (
                    <>
                      <h2>{label}</h2>
                      <Fragment set:html={skill.sections[key] || ''} />
                    </>
                  ) : null
                )}
              </div>
            </details>
          )}

          <h2>Source</h2>
          <div class="source-links">
            <a class="link source-link" href={githubFileUrl} target="_blank" rel="noopener">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18a10.96 10.96 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.79.56C20.71 21.39 24 17.08 24 12c0-6.35-5.15-11.5-11.5-11.5z"/></svg>
              View on GitHub
            </a>
            <a class="link source-link" href={githubEditUrl} target="_blank" rel="noopener">Edit this page</a>
            <a class="link source-link" href={githubIssueUrl} target="_blank" rel="noopener">Open an issue</a>
          </div>
        </article>

        <aside class="skill-aside">
          <div class="card use-card">
            <div class="use-header">
              <span class="mono">USE THIS SKILL</span>
              <span class="use-rule" aria-hidden="true"></span>
            </div>

            <div class="action-row">
              <button id="copy-btn" class="btn btn-accent action-copy">
                <svg id="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
                <svg id="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: none;">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span id="copy-label">Copy skill</span>
              </button>
              <button id="md-btn" class="btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                <span id="md-label">.md</span>
              </button>
            </div>

            <p class="paste-hint">Then paste it into a fresh chat:</p>
            <div class="paste-row">
              {pasteTargets.map((t) => (
                <a class="btn btn-sm paste-btn" href={t.url} target="_blank" rel="noopener">
                  <span>{t.name}</span>
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              ))}
            </div>

            <p class="wrapper-hint">
              Prepend one line: <em>"Use the above as your guide, then ask me what I want to work on."</em>
            </p>
          </div>

          <div class="power-block">
            <div class="power-header mono">POWER USERS</div>
            <p class="power-desc">
              For Claude Code, Codex, Cursor, or Gemini CLI — tools that load
              bundled skill folders directly.
            </p>
            <a class="btn btn-sm power-btn" href={githubFolderUrl} target="_blank" rel="noopener">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
              </svg>
              <span>View skill folder on GitHub</span>
            </a>
            <pre class="power-paths"><span class="power-paths-comment"># drop into one of</span>
~/.claude/skills/
~/.codex/skills/
.agents/skills/   <span class="power-paths-comment">// project-level</span></pre>
          </div>
        </aside>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ skillMarkdown: skill.bodyMarkdown, frontmatter: { name: skill.slug, description: skill.description }, fileSlug: skill.slug, baseUrl }}>
  // Breadcrumb back-link uses History.back when there's history, else fallback to home.
  const breadcrumb = document.querySelector('.breadcrumb');
  if (breadcrumb) {
    const backUrl = breadcrumb.getAttribute('data-back-url');
    breadcrumb.addEventListener('click', () => {
      if (window.history.length > 1) window.history.back();
      else if (backUrl) window.location.href = backUrl;
    });
  }

  function buildSkillMd() {
    const fm = `---\nname: ${frontmatter.name}\ndescription: "${(frontmatter.description || '').replace(/"/g, '\\"').replace(/\n/g, ' ')}"\n---\n\n`;
    return fm + (skillMarkdown || '');
  }

  const copyBtn = document.getElementById('copy-btn');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  const copyLabel = document.getElementById('copy-label');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const md = buildSkillMd();
      try {
        await navigator.clipboard.writeText(md);
        if (copyIcon) copyIcon.style.display = 'none';
        if (checkIcon) checkIcon.style.display = '';
        if (copyLabel) copyLabel.textContent = 'Copied';
        setTimeout(() => {
          if (copyIcon) copyIcon.style.display = '';
          if (checkIcon) checkIcon.style.display = 'none';
          if (copyLabel) copyLabel.textContent = 'Copy skill';
        }, 2000);
      } catch (e) {
        console.error(e);
      }
    });
  }

  const mdBtn = document.getElementById('md-btn');
  const mdLabel = document.getElementById('md-label');
  if (mdBtn) {
    mdBtn.addEventListener('click', () => {
      const md = buildSkillMd();
      const blob = new Blob([md], { type: 'text/markdown;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${fileSlug}.md`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 0);
      if (mdLabel) {
        mdLabel.textContent = 'Saved';
        setTimeout(() => { mdLabel.textContent = '.md'; }, 2000);
      }
    });
  }
</script>

<style>
  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .skill-page-wrap {
    padding: 24px 0 0;
  }

  /* Breadcrumb */
  .breadcrumb {
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink-3);
    font: inherit;
    font-size: 13px;
    padding: 6px 0;
    margin-bottom: 16px;
  }
  .breadcrumb:hover { color: var(--ink); }

  /* Header */
  .skill-header { margin-bottom: 32px; }
  .header-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .header-cat {
    font-size: 11px;
    color: var(--ink-4);
  }
  .skill-title {
    font-size: clamp(34px, 4.4vw, 48px);
    margin: 0;
    color: var(--ink);
    max-width: 800px;
  }
  .skill-sub {
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 20px 0 0;
    max-width: 720px;
  }
  .metadata-row {
    display: flex;
    gap: 24px;
    margin-top: 24px;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--ink-3);
  }
  .meta-val {
    color: var(--ink-2);
    margin-left: 4px;
  }
  .meta-tools {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tool-dot-row {
    display: flex;
    gap: 4px;
  }
  .tool-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: var(--bg-sunken);
    border: 1px solid var(--line-2);
    color: var(--ink-2);
  }

  /* Implementation-details collapsible */
  .impl-details {
    margin: 32px 0;
    border: 1px dashed var(--line);
    border-radius: 10px;
    padding: 0;
  }
  .impl-details summary {
    padding: 14px 18px;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    color: var(--ink-3);
  }
  .impl-details summary::-webkit-details-marker { display: none; }
  .impl-details summary:hover { color: var(--ink); }
  .impl-summary-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .impl-summary-hint {
    font-size: 13px;
    color: var(--ink-4);
  }
  .impl-details[open] summary {
    border-bottom: 1px dashed var(--line);
  }
  .impl-body {
    padding: 0 18px 18px;
  }

  /* Two-column body / sidebar */
  .skill-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 48px;
    align-items: start;
  }

  .skill-body {
    min-width: 0;
  }

  /* Triggers — overrides on top of .md */
  .trigger-block {
    margin-bottom: 16px;
  }
  .trigger-block:last-child { margin-bottom: 0; }
  .trigger-label {
    font-size: 11px;
    color: var(--ink-3);
    margin-bottom: 8px;
  }
  .trigger-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .trigger-chip {
    display: inline-block;
    width: fit-content;
    font-size: 13px;
  }
  .trigger-prose {
    font-size: 14px !important;
    color: var(--ink-2) !important;
    margin: 0 !important;
  }

  /* Source links */
  .source-links {
    display: flex;
    gap: 18px;
    font-size: 14px;
    flex-wrap: wrap;
  }
  .source-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  /* Sidebar */
  .skill-aside {
    position: sticky;
    top: 80px;
  }
  .use-card {
    padding: 20px;
  }
  .use-header {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ink-3);
    margin-bottom: 14px;
  }
  .use-header .mono {
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .use-rule {
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .action-row {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
  }
  .action-copy {
    flex: 1;
    justify-content: center;
  }

  .paste-hint {
    font-size: 13px;
    color: var(--ink-3);
    margin: 0 0 8px;
    line-height: 1.5;
  }
  .paste-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .paste-btn {
    flex: 1 1 auto;
    justify-content: center;
    text-decoration: none;
  }

  .wrapper-hint {
    font-size: 12px;
    color: var(--ink-4);
    margin: 14px 0 0;
    line-height: 1.5;
  }
  .wrapper-hint em {
    color: var(--ink-3);
    font-style: italic;
  }

  /* Power users */
  .power-block {
    margin-top: 16px;
    padding: 18px;
    border: 1px dashed var(--line);
    border-radius: 10px;
    background: transparent;
  }
  .power-header {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin-bottom: 12px;
  }
  .power-desc {
    font-size: 12px;
    color: var(--ink-3);
    margin: 0 0 12px;
    line-height: 1.5;
  }
  .power-btn {
    width: 100%;
    justify-content: center;
  }
  .power-paths {
    margin: 12px 0 0;
    padding: 10px 12px;
    border-radius: 6px;
    background: var(--code-bg);
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink-2);
    font-family: 'JetBrains Mono', monospace;
    white-space: pre-wrap;
  }
  .power-paths-comment {
    color: var(--ink-4);
    font-size: 11px;
  }

  /* Responsive: stack at narrow widths */
  @media (max-width: 900px) {
    .skill-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .skill-aside {
      position: static;
      order: -1;
    }
  }
  @media (max-width: 720px) {
    .container { padding: 0 20px; }
    .metadata-row { gap: 14px; }
  }
</style>
