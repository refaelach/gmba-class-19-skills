---
import Layout from '../layouts/Layout.astro';
import SkillCard from '../components/SkillCard.astro';
import skillsData from '../data/skills.json';
import categoriesData from '../data/categories.json';

type Skill = {
  slug: string;
  category: string;
  name: string;
  title: string;
  summaryLine: string;
  triggers: { mandatory: string[]; strong: string[] };
  tools: string[];
  testedShort: string;
  footer?: { created?: string };
};

type Category = {
  slug: string;
  title: string;
  description: string;
  skillCount: number;
};

const skills = skillsData as unknown as Skill[];
const categories = categoriesData as unknown as Category[];
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

// Skill rows for SkillCard, with categoryName resolved.
const categoryByslug = Object.fromEntries(categories.map((c) => [c.slug, c]));
const skillRows = skills.map((s) => ({
  skill: {
    slug: s.slug,
    name: s.name,
    title: s.title,
    summary: s.summaryLine,
    category: s.category,
    tools: s.tools || ['Claude', 'ChatGPT', 'Gemini', 'Codex'],
    testedShort: s.testedShort || '',
  },
  categoryName: categoryByslug[s.category]?.title || s.category,
}));

// Search payload: minimal data the dropdown needs.
const searchPayload = skills.map((s) => ({
  slug: s.slug,
  name: s.name,
  title: s.title,
  summary: s.summaryLine,
  category: s.category,
  categoryName: categoryByslug[s.category]?.title || s.category,
  triggers: [...(s.triggers?.mandatory || []), ...(s.triggers?.strong || [])],
}));

// Show all categories on the home page, including empty ones — surfaces the
// full taxonomy and creates a visible "this slot is open, contribute here"
// signal for the cohort. Empty tiles render dimmed and aren't clickable.
const allCategories = categories;
const populatedCategories = categories.filter((c) => c.skillCount > 0);

// Sort skills alphabetically for the All-skills grid.
const allSkillsSorted = [...skillRows].sort((a, b) =>
  a.skill.title.localeCompare(b.skill.title),
);

// Recently added: top 3 by created date (descending), with empty-string fallback.
const recentSkills = [...skillRows]
  .sort((a, b) => {
    const ca = skills.find((x) => x.slug === a.skill.slug)?.footer?.created || '';
    const cb = skills.find((x) => x.slug === b.skill.slug)?.footer?.created || '';
    return cb.localeCompare(ca);
  })
  .slice(0, 3);
---
<Layout title="Browse skills · GMBA Class 19">
  <section class="hero">
    <div class="container">
      <div class="eyebrow mono">GMBA · Class 19</div>
      <h1 class="hero-title h-display">
        Pre-built AI guides, by Class 19, for Class 19.
      </h1>
      <p class="hero-sub">
        Pick one, paste it into ChatGPT or Claude, get better answers.
      </p>
      <p class="hero-meta mono">Open source — fork, use, contribute back.</p>

      <div class="search-shell">
        <div class="search-box">
          <span class="search-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="7"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </span>
          <input
            id="skill-search"
            type="search"
            placeholder="Search skills — try 'WACC', 'case', 'memo'…"
            autocomplete="off"
            aria-label="Search skills"
          />
          <a class="search-help h-sans" href={`${baseUrl}/how-to-use`}>How to use →</a>
        </div>
        <div id="search-results" class="search-dropdown card" hidden></div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-label">Categories</h2>
        <span class="section-meta mono">
          {skills.length} skill{skills.length === 1 ? '' : 's'} · {allCategories.length} categories
        </span>
      </div>
      <div class="cat-tile-grid">
        {allCategories.map((c) => {
          const isEmpty = c.skillCount === 0;
          const Tag = isEmpty ? 'div' : 'button';
          return (
            <Tag
              class:list={['cat-tile', isEmpty && 'cat-tile-empty']}
              data-cat-slug={isEmpty ? undefined : c.slug}
              data-cat-name={isEmpty ? undefined : c.title}
            >
              <div class="cat-tile-top">
                <span class="mono cat-tile-slug">{c.slug}</span>
                <span class="mono cat-tile-count">
                  {isEmpty ? 'empty' : String(c.skillCount).padStart(2, '0')}
                </span>
              </div>
              <div class="cat-tile-name h-display">{c.title}</div>
              <div class="cat-tile-desc">{c.description}</div>
              {isEmpty && (
                <div class="cat-tile-empty-cta mono">
                  <a href={`${baseUrl}/contribute`}>Be the first → contribute</a>
                </div>
              )}
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <section class="page-section" id="all-skills">
    <div class="container">
      <h2 class="section-label">All skills</h2>
      <div class="card-grid" id="all-grid">
        {allSkillsSorted.map((row) => (
          <SkillCard skill={row.skill} categoryName={row.categoryName} />
        ))}
      </div>
    </div>
  </section>

  {recentSkills.length > 0 && (
    <section class="page-section">
      <div class="container">
        <h2 class="section-label">Recently added</h2>
        <div class="card-grid">
          {recentSkills.map((row) => (
            <SkillCard skill={row.skill} categoryName={row.categoryName} />
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<script define:vars={{ searchPayload, baseUrl }}>
  // Live search dropdown — filters across name, title, summary, category, triggers.
  const input = document.getElementById('skill-search');
  const dropdown = document.getElementById('search-results');
  const allGrid = document.getElementById('all-grid');
  const catTiles = document.querySelectorAll('.cat-tile');

  function escapeHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function filterSkills(q) {
    const query = q.trim().toLowerCase();
    if (!query) return null;
    return searchPayload
      .filter((s) =>
        s.title.toLowerCase().includes(query) ||
        s.name.toLowerCase().includes(query) ||
        s.summary.toLowerCase().includes(query) ||
        s.categoryName.toLowerCase().includes(query) ||
        s.category.toLowerCase().includes(query) ||
        s.triggers.some((t) => t.toLowerCase().includes(query))
      )
      .slice(0, 6);
  }

  function renderDropdown(results) {
    if (!results) {
      dropdown.hidden = true;
      dropdown.innerHTML = '';
      return;
    }
    dropdown.hidden = false;
    if (results.length === 0) {
      dropdown.innerHTML = `
        <div class="search-empty">
          No matches.
          <a class="link" href="#all-skills">Browse all skills</a>
        </div>`;
      return;
    }
    dropdown.innerHTML = results
      .map(
        (r) => `
        <a class="search-row" href="${baseUrl}/skills/${r.slug}">
          <div class="search-row-text">
            <div class="search-row-title h-sans">${escapeHtml(r.title)}</div>
            <div class="search-row-summary">${escapeHtml(r.summary)}</div>
          </div>
          <span class="chip">${escapeHtml(r.categoryName)}</span>
        </a>
      `,
      )
      .join('');
  }

  if (input) {
    input.addEventListener('input', (e) => {
      const results = filterSkills(e.target.value);
      renderDropdown(results);
    });
    input.addEventListener('blur', () => {
      // Delay so click on a result fires before we hide.
      setTimeout(() => {
        dropdown.hidden = true;
      }, 180);
    });
    input.addEventListener('focus', (e) => {
      const results = filterSkills(e.target.value);
      renderDropdown(results);
    });
  }

  // Category tile click → seed the search with the category name and scroll up.
  catTiles.forEach((tile) => {
    tile.addEventListener('click', () => {
      const name = tile.getAttribute('data-cat-name') || '';
      if (input) {
        input.value = name;
        input.focus();
        renderDropdown(filterSkills(name));
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  });
</script>

<style>
  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Hero */
  .hero {
    border-bottom: 1px solid var(--line);
    padding: 88px 0 56px;
  }
  .eyebrow {
    font-size: 12px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    margin-bottom: 28px;
  }
  .hero-title {
    font-size: clamp(40px, 5.4vw, 64px);
    color: var(--ink);
    margin: 0;
    max-width: 880px;
  }
  .hero-sub {
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 24px 0 0;
    max-width: 640px;
  }
  .hero-meta {
    font-size: 12px;
    color: var(--ink-4);
    margin: 12px 0 0;
  }

  /* Inline search */
  .search-shell {
    margin-top: 40px;
    max-width: 560px;
    position: relative;
  }
  .search-box {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 52px;
    padding: 0 14px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg-elev);
  }
  .search-icon {
    color: var(--ink-3);
    display: inline-flex;
    align-items: center;
  }
  #skill-search {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font: inherit;
    font-size: 16px;
    color: var(--ink);
  }
  .search-help {
    font-size: 13px;
    color: var(--ink-3);
    padding: 4px 0 4px 12px;
    border-left: 1px solid var(--line);
    text-decoration: none;
    white-space: nowrap;
  }
  .search-help:hover { color: var(--ink); text-decoration: none; }

  .search-dropdown {
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    z-index: 20;
    padding: 6px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }
  .search-dropdown[hidden] { display: none; }
  .search-empty {
    padding: 14px 12px;
    color: var(--ink-3);
    font-size: 14px;
  }
  .search-empty a { margin-left: 4px; }

  :global(.search-row) {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 10px 12px;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
  }
  :global(.search-row:hover) { background: var(--bg-sunken); }
  :global(.search-row-text) { flex: 1; min-width: 0; }
  :global(.search-row-title) {
    font-size: 14px;
    color: var(--ink);
    font-weight: 500;
  }
  :global(.search-row-summary) {
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Page section */
  .page-section {
    padding: 56px 0 0;
  }
  .page-section + .page-section { padding-top: 48px; }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .section-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin: 0 0 24px;
  }
  .section-head .section-label { margin: 0; }
  .section-meta {
    font-size: 12px;
    color: var(--ink-4);
  }

  /* Categories tile grid — 1px hairline gaps, single bordered container */
  .cat-tile-grid {
    display: grid;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .cat-tile {
    background: var(--bg-elev);
    border: none;
    padding: 24px 22px;
    text-align: left;
    color: inherit;
    font: inherit;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 132px;
    transition: background 120ms;
  }
  .cat-tile:hover { background: var(--bg-sunken); }
  .cat-tile-empty {
    cursor: default;
    background: var(--bg-elev);
    opacity: 0.62;
  }
  .cat-tile-empty:hover { background: var(--bg-elev); }
  .cat-tile-empty-cta {
    margin-top: auto;
    font-size: 11px;
    padding-top: 2px;
  }
  .cat-tile-empty-cta a {
    color: var(--accent);
    text-decoration: none;
  }
  .cat-tile-empty-cta a:hover { text-decoration: underline; }
  .cat-tile-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .cat-tile-slug {
    font-size: 11px;
    color: var(--ink-4);
  }
  .cat-tile-count {
    font-size: 11px;
    color: var(--ink-3);
  }
  .cat-tile-name {
    font-size: 22px;
    color: var(--ink);
  }
  .cat-tile-desc {
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.45;
  }

  /* Skill cards grid */
  .card-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  @media (max-width: 720px) {
    .container { padding: 0 20px; }
    .hero { padding: 56px 0 40px; }
    .hero-title { font-size: 32px; }
    .page-section { padding-top: 40px; }
    .search-shell { max-width: none; }
  }
</style>
