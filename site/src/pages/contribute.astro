---
import Layout from '../layouts/Layout.astro';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const repoUrl = 'https://github.com/refaelach/gmba-class-19-skills';

const emailBody = `Hi Rafa,

I have a skill I'd like to share with the cohort.

WHAT IT DOES (one sentence):
[describe what the skill does]

CATEGORY:
[research / writing / analysis / decision-making / exam-or-class-prep / productivity]

WHAT YOU SAY TO START IT (1-3 phrases):
- [phrase one]
- [phrase two]

THE PROMPT / INSTRUCTIONS:
[paste the actual prompt you give the AI]

ONE EXAMPLE:
What I typed: [paste]
What the AI gave back: [paste]

ME:
Name / handle: [your name]
Used for: [class, assignment, optional]

Thanks!
`;

const issueBody = `## What does it do?
(one sentence)

## Category
(research / writing / analysis / decision-making / exam-or-class-prep / productivity)

## Trigger phrases
What you'd say to start it. List 1-3.

## The prompt / instructions
Paste the actual prompt you give the AI.

## Example
**What I typed:**

>

**What the AI gave back:**

`;

const mailtoUrl = `mailto:Rephaell@gmail.com?subject=${encodeURIComponent('Skill submission')}&body=${encodeURIComponent(emailBody)}`;
const issueUrl = `${repoUrl}/issues/new?title=${encodeURIComponent('Skill proposal: ')}&body=${encodeURIComponent(issueBody)}`;
---
<Layout title="Contribute · GMBA Class 19">
  <article class="placeholder-page">
    <div class="page-tag mono">contribute</div>
    <h1 class="h-display">Share a prompt that worked.</h1>
    <p>
      Spent two hours coaching ChatGPT through a case prep, a marketing brief, an ops
      framework? Three quick questions and the rest of Class 19 can run the same thing
      in 30 seconds.
    </p>
    <p>
      The friendly contribute form is the next thing landing on this site. For now,
      pick the path that fits:
    </p>

    <div class="path-grid">
      <a class="path-card" href={mailtoUrl}>
        <div class="path-title h-display">Email it to Rafa</div>
        <div class="path-desc">No GitHub needed. Send your prompt, your example, and your name. Rafa drafts the SKILL.md and ships the PR.</div>
        <div class="path-cta mono">Open email →</div>
      </a>
      <a class="path-card" href={issueUrl} target="_blank" rel="noopener">
        <div class="path-title h-display">Open a GitHub issue</div>
        <div class="path-desc">If you have a GitHub account and want to propose a skill before drafting it. Reviewers will respond with feedback.</div>
        <div class="path-cta mono">New issue →</div>
      </a>
      <a class="path-card" href={`${repoUrl}/blob/main/CONTRIBUTING.md`} target="_blank" rel="noopener">
        <div class="path-title h-display">Open a pull request</div>
        <div class="path-desc">If you've already drafted a SKILL.md. Read the full contribution flow and submit through GitHub directly.</div>
        <div class="path-cta mono">Read the rules →</div>
      </a>
    </div>

    <p class="back">
      <a href={baseUrl + '/'}>← Back to all skills</a>
    </p>
  </article>
</Layout>

<style>
  .placeholder-page {
    max-width: 880px;
    margin: 0 auto;
    padding: 80px 32px 0;
  }
  .page-tag {
    font-size: 11px;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }
  h1 {
    font-size: clamp(34px, 4.4vw, 48px);
    margin: 0 0 24px;
    font-weight: 500;
    line-height: 1.08;
  }
  p {
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 18px;
    max-width: 640px;
  }
  .path-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
    margin: 32px 0 32px;
  }
  .path-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg);
    color: var(--ink);
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }
  .path-card:hover {
    border-color: var(--ink-3);
    transform: translateY(-1px);
  }
  .path-title {
    font-size: 17px;
    font-weight: 500;
  }
  .path-desc {
    font-size: 13.5px;
    color: var(--ink-2);
    line-height: 1.55;
    flex: 1;
  }
  .path-cta {
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }
  .back {
    margin-top: 16px;
  }
  .back a {
    font-size: 13px;
    color: var(--ink-3);
    text-decoration: none;
  }
  .back a:hover { color: var(--ink); }

  @media (max-width: 720px) {
    .placeholder-page { padding: 56px 20px 0; }
  }
</style>
