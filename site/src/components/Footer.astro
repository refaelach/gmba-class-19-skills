---
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const repoUrl = 'https://github.com/refaelach/gmba-class-19-skills';
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="mono footer-meta">gmba-class-19-skills · MIT · maintained by @refaelach</div>
    <div class="footer-links">
      <a class="link" href={repoUrl}>GitHub</a>
      <a class="link" href={`${repoUrl}/blob/main/LICENSE`}>License</a>
      <a class="link" href={`${baseUrl}/contribute`}>Contribute</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: 80px;
    padding: 32px 32px 48px;
  }
  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .footer-meta {
    font-size: 12px;
    color: var(--ink-3);
  }
  .footer-links {
    display: flex;
    gap: 20px;
    font-size: 13px;
  }
</style>
