---
interface Props {
  skill: {
    slug: string;
    name: string;
    title: string;
    summary: string;
    category: string;
    tools: string[];
    testedShort: string;
  };
  categoryName: string;
}

const { skill, categoryName } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${baseUrl}/skills/${skill.slug}`;
const tools = (skill.tools || []).slice(0, 4);
---
<a class="card card-hover skill-card" href={href}>
  <div class="skill-meta">
    <span class="mono skill-cat">{categoryName}</span>
    <span class="skill-dot" aria-hidden="true"></span>
    <span class="mono skill-name">{skill.name}</span>
  </div>
  <h3 class="h-display skill-title">{skill.title}</h3>
  <p class="skill-summary">{skill.summary}</p>
  <div class="skill-foot">
    <div class="skill-tools">
      {tools.map((t) => (
        <span class="tool-dot" title={t}>{t.charAt(0).toUpperCase()}</span>
      ))}
    </div>
    <span class="mono skill-tested">tested · {skill.testedShort}</span>
  </div>
</a>

<style>
  .skill-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px;
    text-decoration: none;
    color: inherit;
  }
  .skill-card:hover { text-decoration: none; }
  .skill-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ink-4);
  }
  .skill-cat {
    font-size: 11px;
    color: var(--ink-3);
  }
  .skill-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--ink-4);
    display: inline-block;
  }
  .skill-name {
    font-size: 11px;
    color: var(--ink-4);
  }
  .skill-title {
    font-size: 22px;
    line-height: 1.15;
    color: var(--ink);
    margin: 0;
  }
  .skill-summary {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    flex: 1;
  }
  .skill-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 10px;
    border-top: 1px solid var(--line-2);
    margin-top: 4px;
  }
  .skill-tools {
    display: flex;
    gap: 4px;
  }
  .tool-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: var(--bg-sunken);
    border: 1px solid var(--line-2);
    color: var(--ink-3);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
  }
  .skill-tested {
    font-size: 11px;
    color: var(--ink-4);
  }
</style>
